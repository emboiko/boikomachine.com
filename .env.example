# MongoDB Atlas connection string
MONGODB_URI=

# Vercel Blob — use BLOB_READ_WRITE_TOKEN (private store; set access in code, not dashboard-only)
BLOB_READ_WRITE_TOKEN=

# Resend API key (https://resend.com)
RESEND_API_KEY=

# Cloudflare Turnstile (https://dash.cloudflare.com)
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Google Analytics 4 measurement ID (production only unless override below)
GA_MEASUREMENT_ID=

# Force custom analytics on locally: NEXT_PUBLIC_ANALYTICS_ENABLED=true
# Force off on production: NEXT_PUBLIC_ANALYTICS_ENABLED=false

# Public site URL (used for SEO metadata and sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin auth (generate hash with: npm run hash:admin-password)
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
